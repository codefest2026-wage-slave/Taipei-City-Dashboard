# scripts/food_safety_inspection_metrotaipei/.env.script.example
#
# Copy to scripts/food_safety_inspection_metrotaipei/.env.script (gitignored)
# and fill in the right values for your target environment. Sourced by
# _db_env.sh (which is in turn sourced by apply.sh / rollback.sh /
# backup_db.sh) and read by etl/_db.py.
#
# Two profiles below — uncomment ONE block and adjust.

# ── Local docker (postgres-data container up, attached to br_dashboard) ──
# postgres-data has NO host port mapping in docker/docker-compose-db.yaml,
# so the temp psql client must join br_dashboard and use the internal
# hostname. PG_DOCKER_NETWORK=br_dashboard tells the runner to do that.
DB_DASHBOARD_HOST=postgres-data
DB_DASHBOARD_PORT=5432
DB_DASHBOARD_USER=postgres
DB_DASHBOARD_PASSWORD=test1234
DB_DASHBOARD_DBNAME=dashboard
DB_DASHBOARD_SSLMODE=disable
PG_DOCKER_NETWORK=br_dashboard

# Postgres client image used by docker run. Keep >= server major version.
# (docker-compose-db.yaml uses postgis/postgis:16-3.4-alpine, so 16 is fine.)
# PG_CLIENT_IMAGE=postgres:16

# ── Cloud (team's shared DB) ──────────────────────────────────────────
# Set PG_DOCKER_NETWORK=host so the temp psql container resolves the
# public hostname through the host's network stack.
# DB_DASHBOARD_HOST=your-cloud-host.example.com
# DB_DASHBOARD_PORT=5432
# DB_DASHBOARD_USER=your_user
# DB_DASHBOARD_PASSWORD=your_password
# DB_DASHBOARD_DBNAME=dashboard
# DB_DASHBOARD_SSLMODE=require
# PG_DOCKER_NETWORK=host

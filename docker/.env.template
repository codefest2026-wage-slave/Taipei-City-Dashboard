# Redis Configs
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# pgadmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_LISTEN_PORT=80

# Qdrant Configs
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your_api_key

# scripts/food_safety/.env.script.example
#
# Copy to scripts/food_safety/.env.script (gitignored) and fill in the
# right values for your target environment. Sourced by _db_env.sh which
# is in turn sourced by apply.sh / rollback.sh / backup_db.sh and read
# by the Python ETL loaders.
#
# Two profiles below — uncomment ONE block and adjust as needed.

# ── Local docker (postgres-data + postgres-manager containers up) ────
DB_DASHBOARD_HOST=localhost
DB_DASHBOARD_PORT=5433
DB_DASHBOARD_USER=postgres
DB_DASHBOARD_PASSWORD=test1234
DB_DASHBOARD_DBNAME=dashboard
DB_DASHBOARD_SSLMODE=disable

DB_MANAGER_HOST=localhost
DB_MANAGER_PORT=5432
DB_MANAGER_USER=postgres
DB_MANAGER_PASSWORD=test1234
DB_MANAGER_DBNAME=dashboardmanager
DB_MANAGER_SSLMODE=disable

# Postgres client image used by docker run. Bump if your server is newer.
# (cloud is currently 17.x; local docker is 16.x. Default is postgres:17,
#  which is forward-compatible with 16.x server too.)
# PG_CLIENT_IMAGE=postgres:17

# ── Cloud (team's shared DB) ────────────────────────────────────────
# DB_DASHBOARD_HOST=your-cloud-host.example.com
# DB_DASHBOARD_PORT=5432
# DB_DASHBOARD_USER=your_user
# DB_DASHBOARD_PASSWORD=your_password
# DB_DASHBOARD_DBNAME=dashboard
# DB_DASHBOARD_SSLMODE=require
#
# DB_MANAGER_HOST=your-cloud-host.example.com
# DB_MANAGER_PORT=5432
# DB_MANAGER_USER=your_user
# DB_MANAGER_PASSWORD=your_password
# DB_MANAGER_DBNAME=dashboardmanager
# DB_MANAGER_SSLMODE=require
